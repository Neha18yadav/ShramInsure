PORT=5001
JWT_SECRET=shraminsure_super_secret_jwt_key_2026
DB_PATH=./shraminsure.db
NODE_ENV=development

# Weather API (OpenWeatherMap) — optional, falls back to mock data
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# AQI API (IQAir / AirVisual) — optional, falls back to mock data
IQAIR_API_KEY=your_iqair_api_key_here

# Payment Gateway (Razorpay) — optional, falls back to simulation mode
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_SECRET=your_razorpay_secret_here

# Frontend URL (for CORS in production)
FRONTEND_URL=http://localhost:5173
